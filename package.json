{
  "name": "revision-facturacion-visitas",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"tsc -p tsconfig.main.json --watch\" \"vite --port 5173\" \"wait-on tcp:5173 dist/main/main.js dist/main/preload.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist/main/main.js\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "preview": "vite preview",
    "dist:app": "npm run build",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.8",
    "electron-builder": "^24.13.3",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jointwelding.facturacionvisitas",
    "productName": "Facturacion Visitas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
